{
  "buildCommand": "echo 'Build complete'",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)\\.(mp3|wav|ogg|webm)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        },
        {
          "key": "Content-Type",
          "value": "audio/mpeg"
        },
        {
          "key": "Accept-Ranges",
          "value": "bytes"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ]
}